/* Input Settings panel styles */

#content-wrap {
    overflow-y: auto;
}

.is-section {
    margin-bottom: 6dp;
}

.is-section-title {
    font-size: 10dp;
    font-weight: bold;
    margin-bottom: 2dp;
}

.is-hint {
    display: block;
    font-size: 11dp;
    margin-bottom: 4dp;
}

.is-row {
    display: flex;
    align-items: center;
    gap: 8dp;
    margin-bottom: 4dp;
}

.is-label {
    min-width: 100dp;
    font-size: 10dp;
}

.is-select {
    flex: 1;
    min-width: 140dp;
}

/* ── Bindings table ────────────────────────────────────── */

.is-bindings-table {
    margin-top: 4dp;
    margin-bottom: 6dp;
}

.is-binding-section {
    display: block;
    font-size: 11dp;
    font-weight: bold;
    padding: 3dp 4dp;
    margin-top: 4dp;
}

.is-binding-row {
    display: flex;
    align-items: center;
    padding: 2dp 4dp;
    min-height: 22dp;
}

.is-action-name {
    width: 160dp;
    font-size: 10dp;
    flex-shrink: 0;
}

.is-binding-desc {
    flex: 1;
    font-size: 10dp;
    min-width: 0;
}

.is-rebind-btn {
    flex-shrink: 0;
    min-width: 60dp;
    font-size: 11dp;
    padding: 1dp 6dp;
}

/* ── Action buttons ────────────────────────────────────── */

.is-buttons {
    display: flex;
    gap: 6dp;
    margin-top: 6dp;
    margin-bottom: 4dp;
}

/* ── Disabled overlay for selects during capture ──────── */

.is-disabled-overlay {
    opacity: 0.4;
    pointer-events: none;
}

/* ── Binding conflict confirmation ────────────────────── */

.is-conflict-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 50;
}

.is-conflict-overlay.hidden {
    display: none;
}

.is-conflict-dialog {
    border-width: 1dp;
    border-radius: 6dp;
    padding: 14dp;
    min-width: 280dp;
    max-width: 380dp;
}

.is-conflict-title {
    display: block;
    font-size: 12dp;
    font-weight: bold;
    margin-bottom: 6dp;
}

.is-conflict-message {
    display: block;
    font-size: 11dp;
    margin-bottom: 8dp;
}

.is-conflict-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 8dp;
    margin-top: 8dp;
}

.is-conflict-buttons .btn {
    min-width: 80dp;
}
