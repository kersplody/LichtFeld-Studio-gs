#content-wrap {
    padding: 0;
    overflow: hidden;
    min-width: 0;
    min-height: 0;
}

#content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    min-width: 0;
    min-height: 0;
}

.dock-drag-handle {
    flex: 0 0 auto;
    height: 8dp;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 3dp;
}

.dock-drag-handle-bar {
    width: 36dp;
    height: 3dp;
    background-color: rgba(108, 112, 134, 160);
    border-radius: 2dp;
}

.dock-drag-handle:hover .dock-drag-handle-bar {
    background-color: rgba(137, 180, 250, 220);
}

.dock-drag-handle.hidden {
    display: none;
}

#histogram-shell {
    flex: 1;
    padding: 8dp 10dp 12dp;
    display: flex;
    flex-direction: column;
    gap: 8dp;
    overflow: hidden;
    min-width: 0;
    min-height: 0;
}

#histogram-shell.is-floating {
    padding-top: 10dp;
}

#histogram-floating-header {
    min-height: 28dp;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8dp;
    padding: 0 4dp;
}

#histogram-floating-title {
    font-size: 12dp;
    font-weight: bold;
    color: #cdd6f4;
}

.histogram-panel-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6dp;
}

.histogram-panel-actions--floating {
    flex-shrink: 0;
}

.histogram-panel-action {
    min-width: 64dp;
}

#histogram-hero,
.stat-card,
#histogram-card,
.empty-card,
#compare-card,
#histogram-footer {
    background-color: rgba(30, 30, 46, 236);
    border-width: 1dp;
    border-color: rgba(88, 91, 112, 148);
}

#histogram-hero {
    display: flex;
    gap: 22dp;
    align-items: center;
    justify-content: flex-start;
    padding: 12dp 16dp;
    decorator: vertical-gradient(rgba(49,50,68,228) rgba(30,30,46,236));
    border-radius: 14dp;
    min-width: 0;
}

.hero-copy {
    flex: 0 1 330dp;
    display: flex;
    flex-direction: column;
    gap: 3dp;
    min-width: 0;
}

.hero-eyebrow {
    font-size: 8dp;
    letter-spacing: 0.8dp;
    color: #a6adc8;
    text-transform: uppercase;
}

.hero-title {
    font-size: 17dp;
    font-weight: bold;
    color: #cdd6f4;
}

.hero-description {
    font-size: 10dp;
    color: #a6adc8;
}

#histogram-docked-controls {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 0;
    padding-left: 16dp;
    border-left-width: 1dp;
    border-left-color: rgba(69, 71, 90, 180);
}

#histogram-floating-controls {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8dp;
}

.histogram-toolbar-row {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 12dp;
    width: 100%;
    min-width: 0;
}

.histogram-inline-label {
    min-width: 0;
    flex-shrink: 0;
    white-space: nowrap;
}

.histogram-toolbar-item {
    display: flex;
    align-items: center;
    gap: 8dp;
    min-width: 0;
}

.histogram-toolbar-item--select {
    flex: 0 1 248dp;
}

.histogram-toolbar-item--slider {
    flex: 0 1 260dp;
}

.histogram-toolbar-item--compare-bins {
    flex: 0 1 196dp;
}

.histogram-toolbar-item--toggle {
    flex: 0 0 auto;
}

.histogram-toolbar-item--action {
    flex: 0 0 auto;
    margin-left: 4dp;
}

#histogram-docked-controls .histogram-toolbar-item {
    min-height: 32dp;
    padding: 6dp 10dp;
    background-color: rgba(49, 50, 68, 214);
    border-width: 1dp;
    border-color: rgba(69, 71, 90, 180);
    border-radius: 10dp;
}

#histogram-docked-controls .histogram-toolbar-item--select {
    flex: 0 1 232dp;
}

#histogram-docked-controls .histogram-toolbar-item--slider {
    flex: 0 1 248dp;
}

#histogram-docked-controls .histogram-toolbar-item--compare-bins {
    flex: 0 1 188dp;
}

#histogram-docked-controls .histogram-toolbar-item--toggle {
    padding-right: 10dp;
}

#histogram-docked-controls .histogram-toolbar-item--action {
    padding: 0;
    background-color: transparent;
    border-width: 0;
    margin-left: 2dp;
}

#histogram-docked-controls .control-label {
    font-size: 10dp;
    font-weight: 600;
    color: #bac2de;
}

#histogram-docked-controls .histogram-select {
    min-width: 124dp;
    height: 22dp;
    min-height: 22dp;
    background-color: rgba(24, 24, 37, 226);
    border-color: rgba(88, 91, 112, 200);
}

#histogram-docked-controls .histogram-slider-value {
    min-width: 20dp;
}

#histogram-docked-controls .histogram-panel-action {
    min-width: 76dp;
    min-height: 32dp;
}

.histogram-toggle-control {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 26dp;
}

.histogram-toggle-control input[type="checkbox"] {
    margin-right: 0;
}

.control-label {
    font-size: 9dp;
    font-weight: 600;
    letter-spacing: 0.3dp;
    color: #bac2de;
}

.histogram-select {
    width: 100%;
    flex: 1;
}

.histogram-setting-slider {
    width: 100%;
    flex: 1;
    min-width: 84dp;
    margin-top: 0;
    position: static;
    top: auto;
}

.histogram-slider-value {
    min-width: 28dp;
    text-align: right;
    font-size: 10dp;
    color: #cdd6f4;
}

.floating-controls-row {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 8dp 12dp;
    width: 100%;
    min-width: 0;
}

.floating-control-group {
    display: flex;
    align-items: center;
    gap: 8dp;
    min-width: 0;
}

.floating-control-group--select {
    flex: 1 1 260dp;
}

.floating-control-group--toggle {
    flex: 0 0 auto;
}

.floating-control-group--slider {
    flex: 1 1 260dp;
}

#histogram-shell.is-floating #histogram-hero {
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    gap: 10dp;
    padding: 12dp 14dp;
}

#histogram-shell.is-floating .control-label {
    font-size: 9dp;
    font-weight: 600;
    letter-spacing: 0.3dp;
    text-transform: none;
    color: #bac2de;
}

#histogram-shell.is-floating .hero-title {
    font-size: 17dp;
}

#histogram-shell.is-floating .hero-description {
    font-size: 9dp;
}

#histogram-shell.is-floating .hero-copy {
    flex: 0 0 auto;
}

.floating-control-label {
    min-width: 86dp;
    flex-shrink: 0;
}

#histogram-empty {
    flex: 1;
    min-height: 0;
}

.empty-card {
    height: 100%;
    min-height: 220dp;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8dp;
    padding: 18dp;
    decorator: none;
    border-radius: 14dp;
    text-align: center;
}

.empty-title {
    font-size: 16dp;
    font-weight: bold;
    color: #cdd6f4;
}

.empty-message {
    max-width: 420dp;
    font-size: 10dp;
    color: #a6adc8;
    line-height: 1.45;
}

#histogram-content {
    display: flex;
    flex-direction: column;
    gap: 10dp;
    flex: 1;
    overflow-x: hidden;
    overflow-y: auto;
    padding-right: 4dp;
    min-width: 0;
    min-height: 0;
}

#histogram-stats {
    display: flex;
    gap: 6dp;
    flex-shrink: 0;
    overflow-x: auto;
    overflow-y: hidden;
}

.stat-card {
    flex: 0 0 auto;
    min-width: 112dp;
    padding: 8dp 10dp;
    display: flex;
    flex-direction: column;
    gap: 3dp;
    decorator: none;
    border-radius: 12dp;
}

.stat-label {
    font-size: 8dp;
    letter-spacing: 0.6dp;
    text-transform: uppercase;
    color: #a6adc8;
}

.stat-value {
    font-size: 14dp;
    font-weight: bold;
    color: #cdd6f4;
}

.stat-value--small {
    font-size: 12dp;
}

#histogram-card,
#compare-card {
    flex: 1;
    min-width: 0;
    min-height: 0;
    padding: 12dp 12dp 10dp;
    display: flex;
    flex-direction: column;
    gap: 8dp;
    decorator: none;
    border-radius: 14dp;
}

#histogram-card-header,
#compare-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14dp;
}

#histogram-summary,
#compare-summary {
    flex: 1;
    font-size: 11dp;
    color: #bac2de;
}

#histogram-bin-count,
#compare-bin-count {
    font-size: 8dp;
    letter-spacing: 0.8dp;
    text-transform: uppercase;
    color: #a6adc8;
}

#histogram-range-of-interest {
    display: flex;
    align-items: center;
    gap: 8dp;
    flex-shrink: 0;
}

.range-of-interest-label {
    font-size: 9dp;
    font-weight: 600;
    letter-spacing: 0.3dp;
    color: #bac2de;
}

.range-input {
    width: 84dp;
    min-width: 60dp;
}

.range-separator {
    color: rgba(186, 194, 222, 180);
    font-size: 11dp;
}

.range-reset {
    min-width: 56dp;
    margin-left: 4dp;
}

.range-reset:disabled {
    color: rgba(186, 194, 222, 100);
}

#compare-range-of-interest {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6dp;
    flex-shrink: 0;
}

.compare-axis-marker {
    font-size: 10dp;
    font-weight: 700;
    letter-spacing: 0.4dp;
    color: #a6adc8;
    margin-left: 6dp;
}

#histogram-chart {
    position: relative;
    flex: 1;
    min-height: 128dp;
    border-width: 1dp;
    border-color: rgba(69, 71, 90, 190);
    border-radius: 12dp;
    background-color: rgba(17, 17, 27, 232);
    overflow: hidden;
}

.histogram-grid-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 1dp;
    background-color: rgba(69, 71, 90, 120);
    pointer-events: none;
}

.histogram-grid-line--top-16 {
    top: 16%;
}

.histogram-grid-line--top-36 {
    top: 36%;
}

.histogram-grid-line--top-56 {
    top: 56%;
}

.histogram-grid-line--top-76 {
    top: 76%;
}

#histogram-bars {
    position: absolute;
    left: 14dp;
    right: 14dp;
    top: 14dp;
    bottom: 14dp;
    display: flex;
    align-items: flex-end;
    cursor: crosshair;
}

#histogram-selection {
    position: absolute;
    top: 0;
    bottom: 0;
    min-width: 2dp;
    border-width: 1dp;
    border-color: rgba(250, 179, 135, 210);
    background-color: rgba(250, 179, 135, 22);
    decorator: none;
    border-radius: 10dp;
    pointer-events: none;
}

.histogram-bar {
    flex: 1;
    min-width: 0;
    height: 100%;
    display: flex;
    align-items: flex-end;
    position: relative;
}

.histogram-bar-fill {
    width: 100%;
    min-height: 1dp;
    decorator: vertical-gradient(rgba(137,180,250,228) rgba(180,190,254,255));
    background-color: rgba(137, 180, 250, 220);
    border-radius: 999dp 999dp 4dp 4dp;
}

.histogram-bar.selected .histogram-bar-fill {
    background-color: rgba(250, 179, 135, 228);
    decorator: vertical-gradient(rgba(250,179,135,236) rgba(245,194,231,255));
}

#histogram-axis {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

#compare-card {
    flex: 0 0 auto;
    min-height: 320dp;
    border-width: 1dp;
    border-color: rgba(88, 91, 112, 148);
}

#compare-empty {
    min-height: 220dp;
}

.compare-empty-card {
    min-height: 220dp;
}

#compare-content {
    display: flex;
    flex-direction: column;
    gap: 8dp;
    flex: 1;
    min-height: 0;
}

#compare-chart-shell {
    display: flex;
    gap: 10dp;
    flex: 1;
    min-height: 260dp;
}

#compare-y-axis {
    width: 78dp;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 2dp;
    padding-bottom: 22dp;
    gap: 8dp;
}

#compare-chart-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8dp;
    min-width: 0;
    min-height: 0;
}

#compare-chart {
    position: relative;
    flex: 1;
    min-height: 240dp;
    border-width: 1dp;
    border-color: rgba(69, 71, 90, 190);
    border-radius: 12dp;
    background-color: rgba(17, 17, 27, 232);
    overflow: hidden;
}

#compare-cells {
    position: absolute;
    left: 14dp;
    right: 14dp;
    top: 14dp;
    bottom: 14dp;
    cursor: crosshair;
}

#compare-selection {
    position: absolute;
    min-width: 2dp;
    min-height: 2dp;
    border-width: 1dp;
    border-color: rgba(250, 179, 135, 210);
    background-color: rgba(250, 179, 135, 22);
    decorator: none;
    border-radius: 10dp;
    pointer-events: none;
}

.compare-cell {
    position: absolute;
    left: 0%;
    top: 0%;
    width: 0%;
    height: 0%;
    padding: 1dp;
    box-sizing: border-box;
}

.compare-cell-fill {
    width: 100%;
    height: 100%;
    min-width: 1dp;
    min-height: 1dp;
    decorator: vertical-gradient(rgba(137,180,250,228) rgba(180,190,254,255));
    background-color: rgba(137, 180, 250, 220);
    border-radius: 4dp;
}

.compare-cell.selected .compare-cell-fill {
    background-color: rgba(250, 179, 135, 228);
    decorator: vertical-gradient(rgba(250,179,135,236) rgba(245,194,231,255));
}

#compare-axis {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12dp;
}

#compare-y-axis-values {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
}

.axis-metric {
    flex-shrink: 0;
    font-size: 8dp;
    letter-spacing: 0.8dp;
    text-transform: uppercase;
    color: #a6adc8;
}

.axis-label {
    font-family: "JetBrains Mono";
    font-size: 10dp;
    color: #bac2de;
}

#histogram-footer {
    min-height: 44dp;
    padding: 8dp 10dp;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12dp;
    flex-shrink: 0;
    min-width: 0;
    border-width: 1dp;
    border-color: rgba(88, 91, 112, 148);
    border-radius: 12dp;
}

.footer-stat {
    display: flex;
    flex-direction: column;
    gap: 1dp;
    min-width: 120dp;
}

.footer-label {
    font-size: 8dp;
    letter-spacing: 0.6dp;
    text-transform: uppercase;
    color: #a6adc8;
}

.footer-value {
    font-family: "JetBrains Mono";
    font-size: 10dp;
    color: #cdd6f4;
}

.footer-hint {
    flex: 1;
    min-width: 160dp;
    color: #a6adc8;
    font-size: 9dp;
}

.footer-history-actions,
.footer-text-actions {
    display: flex;
    align-items: center;
    gap: 8dp;
}

.footer-history-actions {
    padding: 2dp;
    border-width: 1dp;
    border-color: rgba(69, 71, 90, 190);
    border-radius: 10dp;
    background-color: rgba(49, 50, 68, 210);
}

.histogram-history-btn {
    width: 30dp;
    height: 30dp;
    min-width: 30dp;
    padding: 0;
    border-radius: 9dp;
}

.histogram-history-icon {
    display: block;
    width: 16dp;
    height: 16dp;
    margin: 6dp auto 0;
    image-color: rgba(236, 241, 255, 235);
}

.histogram-history-btn:disabled .histogram-history-icon {
    image-color: rgba(188, 194, 214, 118);
}

.footer-text-action {
    min-width: 78dp;
}

#histogram-floating-header.hidden,
#histogram-docked-controls.hidden,
#histogram-floating-controls.hidden,
#histogram-empty.hidden,
#histogram-content.hidden,
#histogram-card.hidden,
#compare-card.hidden,
#compare-empty.hidden,
#compare-content.hidden,
#histogram-selection.hidden,
#compare-selection.hidden,
.hidden {
    display: none;
}
