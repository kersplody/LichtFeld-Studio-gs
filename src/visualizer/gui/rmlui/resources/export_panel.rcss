/* Export panel styles */

#content-wrap {
    min-width: 0;
    overflow-x: hidden;
}

.ep-section {
    margin-bottom: 4dp;
}

.ep-section .setting-row--aligned {
    min-width: 0;
}

.ep-section-title {
    font-size: 10dp;
    font-weight: bold;
    margin-bottom: 4dp;
}

/* ── Format list ─────────────────────────────────────── */

.ep-format-list {
    margin-top: 2dp;
}

.ep-format-option {
    display: flex;
    align-items: center;
    padding: 3dp 6dp;
    cursor: pointer;
    transition: background-color 0.1s quadratic-out;
}

.ep-format-dot {
    width: 8dp;
    height: 8dp;
    border-width: 1dp;
    border-radius: 4dp;
    margin-right: 8dp;
    flex-shrink: 0;
}

.ep-format-name {
    font-size: 10dp;
}

/* ── Model list ──────────────────────────────────────── */

.ep-toggle-row {
    display: flex;
    gap: 4dp;
    margin-bottom: 4dp;
}

.ep-small-btn {
    font-size: 10dp;
    padding: 1dp 8dp;
}

.ep-model-list {
    margin-top: 2dp;
}

.ep-model-row {
    display: flex;
    align-items: center;
    padding: 2dp 4dp;
    min-height: 20dp;
}

.ep-model-row .setting-label {
    flex: 1;
    overflow: hidden;
}

.ep-model-name {
    font-size: 10dp;
}

.ep-model-count {
    font-size: 10dp;
    margin-left: 6dp;
    flex-shrink: 0;
}

.ep-no-models {
    font-size: 10dp;
    padding: 4dp 0;
}

/* ── Action area ─────────────────────────────────────── */

.ep-error {
    display: block;
    font-size: 10dp;
    margin-bottom: 4dp;
}

.ep-buttons {
    display: flex;
    gap: 6dp;
    margin-top: 4dp;
}

.ep-action-btn {
    flex: 1;
    text-align: center;
}

/* ── Progress section ──────────────────────────────── */

@keyframes ep-pulse {
    from { background-color: #89b4fa; }
    to   { background-color: #b4d0fb; }
}

.ep-progress-wrap {
    position: relative;
    margin: 6dp 0;
}

.ep-progress fill {
    animation: ep-pulse 1.2s quadratic-in-out infinite alternate;
}

.ep-stage-text {
    display: block;
    font-size: 10dp;
    margin-bottom: 6dp;
}
